<Page x:Class="Unbound.Dashboard"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Dashboard" Background="{DynamicResource BgColor}">
    <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
        <StackPanel>
            <TextBlock x:Name="StatusText" Text="Статус: Ожидание" Foreground="{DynamicResource TextColor}" HorizontalAlignment="Center" FontSize="16" Margin="0,15,0,2"/>
            <TextBlock x:Name="PingText" Text="Пинг до YouTube: --" Foreground="{DynamicResource SubTextColor}" HorizontalAlignment="Center" FontSize="13" Margin="0,0,0,15"/>

            <Button Content="ЗАПУСК СИСТЕМЫ" Width="200" Height="40" Margin="0,10" Click="StartButton_Click" Background="#4CAF50" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            <Button Content="ОСТАНОВКА" Width="200" Height="40" Click="StopButton_Click" Background="#F44336" Foreground="White" BorderThickness="0" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Page>