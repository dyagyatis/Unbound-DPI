<Window x:Class="Unbound.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Unbound DPI" Height="450" Width="400" WindowStartupLocation="CenterScreen">
    <StackPanel Margin="20">
        <Label Content="Стратегия (загружено из /strategies):" FontWeight="Bold"/>
        <ComboBox x:Name="StrategySelector" Height="30" Margin="0,5,0,10"/>

        <GroupBox Header="Игровой фильтр" Margin="0,0,0,10">
            <StackPanel Margin="5">
                <RadioButton x:Name="GameNone" Content="Стандартный" IsChecked="True"/>
                <RadioButton x:Name="GameTCP" Content="Только TCP"/>
                <RadioButton x:Name="GameAll" Content="TCP + UDP"/>
            </StackPanel>
        </GroupBox>

        <Button Content="ПИНГ-ТЕСТ СТРАТЕГИЙ" Click="RunPingTest_Click" Margin="0,0,0,10" Background="#2196F3" Foreground="White"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="ЗАПУСК" Width="120" Height="40" Click="StartButton_Click" Background="#4CAF50" Foreground="White"/>
            <Button Content="СТОП" Width="120" Height="40" Margin="10,0,0,0" Click="StopButton_Click" Background="#F44336" Foreground="White"/>
        </StackPanel>

        <TextBlock x:Name="StatusText" Text="Статус: Ожидание" HorizontalAlignment="Center" Margin="0,20,0,0"/>
    </StackPanel>
</Window>