<Page x:Class="Unbound.Settings"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Settings" Background="{DynamicResource BgColor}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="20">
            <StackPanel>
                <TextBlock Text="НАСТРОЙКИ СИСТЕМЫ" Foreground="{DynamicResource TextColor}" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

                <CheckBox x:Name="AutostartCheckBox" Content="Запускать Unbound при старте Windows" 
                          Foreground="{DynamicResource TextColor}" FontSize="14" Margin="0,10" Click="Autostart_Click"/>

                <Button Content="Включить TCP Timestamps (Оптимизация)" Width="280" Height="35" 
                        HorizontalAlignment="Left" Margin="0,15,0,5" Click="EnableTimestamps_Click"
                        Background="#1976D2" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                <TextBlock Text="*Включает временные метки TCP, что улучшает десинхронизацию на некоторых провайдерах." 
                           Foreground="{DynamicResource SubTextColor}" FontSize="11" Margin="0,0,0,20" TextWrapping="Wrap"/>

                <Separator Background="{DynamicResource BorderColor}" Margin="0,10"/>

                <TextBlock Text="ВНЕШНИЙ ВИД И ЭФФЕКТЫ" Foreground="{DynamicResource TextColor}" FontSize="16" FontWeight="SemiBold" Margin="0,15,0,10"/>

                <StackPanel Orientation="Horizontal" Margin="0,5">
                    <TextBlock Text="Тема оформления:" Foreground="{DynamicResource TextColor}" FontSize="14" VerticalAlignment="Center" Margin="0,0,15,0"/>
                    <ComboBox x:Name="ThemeSelector" Width="200" Height="25" SelectionChanged="ThemeSelector_SelectionChanged">
                        <ComboBoxItem Content="Автоматически (Системная)" Tag="Auto" IsSelected="True"/>
                        <ComboBoxItem Content="Тёмная" Tag="Dark"/>
                        <ComboBoxItem Content="Светлая" Tag="Light"/>
                    </ComboBox>
                </StackPanel>

                <CheckBox x:Name="AnimationCheckBox" Content="Включить плавные анимации и эффекты" 
                          Foreground="{DynamicResource TextColor}" FontSize="14" Margin="0,15,0,20" 
                          IsChecked="True" Click="Animation_Click"/>

                <Separator Background="{DynamicResource BorderColor}" Margin="0,10"/>

                <TextBlock Text="ОБСЛУЖИВАНИЕ" Foreground="{DynamicResource TextColor}" FontSize="16" FontWeight="SemiBold" Margin="0,10"/>
                <Button Content="Удалить драйвер WinDivert (Сброс сети)" Width="280" Height="35" 
                        HorizontalAlignment="Left" Click="DeleteDriver_Click"
                        Background="#C62828" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                <TextBlock Text="*Используйте, если после закрытия программы «пропал» интернет." 
                           Foreground="{DynamicResource SubTextColor}" FontSize="11" Margin="0,5,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>