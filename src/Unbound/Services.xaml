<Page x:Class="Unbound.Services"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Services" Background="{DynamicResource BgColor}">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <ScrollViewer.Resources>
                <Style TargetType="ScrollBar" BasedOn="{StaticResource {x:Type ScrollBar}}"/>
            </ScrollViewer.Resources>

            <WrapPanel x:Name="ServiceGrid" HorizontalAlignment="Left"/>
        </ScrollViewer>

        <Button Grid.Row="1" Content="Редактировать список сайтов (hostlist)" Width="280" Height="35" 
                HorizontalAlignment="Left" Margin="8,15,0,5" Click="OpenEditor_Click"
                Background="#ff9800" Foreground="Black" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand">
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="5">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Button.Style>
        </Button>

        <Grid x:Name="EditorGrid" Grid.Row="2" Visibility="Collapsed" Margin="8,10,8,0" Height="180">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" CornerRadius="6" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" Background="{DynamicResource CardBgColor}">
                <TextBox x:Name="HostlistTextBox" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                         Background="Transparent" 
                         Foreground="{DynamicResource TextColor}" 
                         BorderThickness="0" 
                         FontFamily="Consolas" FontSize="12" Padding="8,8,15,8">
                    <TextBox.Resources>
                        <Style TargetType="ScrollBar" BasedOn="{StaticResource {x:Type ScrollBar}}"/>
                    </TextBox.Resources>
                </TextBox>
            </Border>

            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                <Button Content="Сохранить" Width="100" Height="30" Click="SaveEditor_Click" Background="#4CAF50" Foreground="White" BorderThickness="0" Margin="0,0,10,0" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Content="Отмена" Width="100" Height="30" Click="CloseEditor_Click" Background="#555" Foreground="White" BorderThickness="0" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</Page>