<Page x:Class="Unbound.About"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="About" Background="{DynamicResource BgColor}">
    <Grid Margin="30">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="UNBOUND HUB" Foreground="#4CAF50" FontSize="36" FontWeight="Bold" HorizontalAlignment="Center"/>
            <TextBlock Text="Версия 1.0.0" Foreground="{DynamicResource SubTextColor}" FontSize="14" HorizontalAlignment="Center" Margin="0,5,0,25"/>

            <TextBlock Text="Графический интерфейс для управления современными стратегиями обхода DPI." 
                       Foreground="{DynamicResource TextColor}" FontSize="14" TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center" Width="400"/>

            <Border Background="{DynamicResource CardBgColor}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,25,0,0" Width="450">
                <StackPanel>
                    <TextBlock Text="БЛАГОДАРНОСТИ" Foreground="{DynamicResource SubTextColor}" FontSize="12" FontWeight="Bold" Margin="0,0,0,10"/>
                    <TextBlock Text="• Движок: zapret2 (winws2) от bol-van" Foreground="{DynamicResource TextColor}" FontSize="13" Margin="0,2"/>
                    <TextBlock Text="• Сетевой модуль: WinDivert Driver" Foreground="{DynamicResource TextColor}" FontSize="13" Margin="0,2"/>
                    <TextBlock Text="• Логика пакетов: Lua desync engine" Foreground="{DynamicResource TextColor}" FontSize="13" Margin="0,2"/>
                </StackPanel>
            </Border>

            <TextBlock Margin="0,30,0,0" HorizontalAlignment="Center">
                <Hyperlink NavigateUri="https://github.com/dyagyatis/Unbound-DPI" RequestNavigate="Hyperlink_RequestNavigate" Foreground="#2196F3">
                    Открыть оригинальный репозиторий zapret
                </Hyperlink>
            </TextBlock>
        </StackPanel>
    </Grid>
</Page>