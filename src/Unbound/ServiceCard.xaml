<UserControl x:Class="Unbound.ServiceCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="100" Width="110" Margin="8">
    <Border x:Name="CardBorder" Background="#2d2d2d" CornerRadius="10" 
            MouseDown="Card_Click" Cursor="Hand" BorderThickness="2" BorderBrush="Transparent">
        <Grid>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock x:Name="TitleText" Text="Service" Foreground="White" 
                           FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>